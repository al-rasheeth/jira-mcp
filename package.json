{
  "name": "jira-mcp",
  "version": "1.0.0",
  "description": "STDIO-based JIRA MCP server with proxy support, caching, and dual Cloud/Data Center API support",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "jira-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "clean": "rm -rf build"
  },
  "keywords": [
    "mcp",
    "jira",
    "atlassian",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "lru-cache": "^11.0.0",
    "undici": "^7.22.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
